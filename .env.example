NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_sessions?schema=public
REDIS_URL=redis://localhost:6379

JWT_ISSUER=safe-ai-session-backend
JWT_AUDIENCE=safe-ai-session-clients
JWT_ACCESS_TTL_SECONDS=86400
JWT_REFRESH_TTL_SECONDS=2592000
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=

COOKIE_ENCRYPTION_KEY_BASE64=
ALLOWED_EMAIL_DOMAINS=vidgen.fun
VIRTUAL_EMAIL_DOMAIN=vidgen.fun
ADMIN_FRONTEND_ORIGINS=https://vidgen.fun,https://admin.vidgen.fun

SUPER_ADMIN_EMAIL=admin@vidgen.fun
SUPER_ADMIN_PASSWORD=change-this-strong-password
SUPER_ADMIN_VALID_DAYS=3650
SUPER_ADMIN_CREDITS_LIMIT=1000000

GLOBAL_RATE_LIMIT_MAX=300
GLOBAL_RATE_LIMIT_WINDOW=1 minute
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute
SESSION_RATE_LIMIT_MAX=120
SESSION_RATE_LIMIT_WINDOW=1 minute
LEASE_TTL_SECONDS=150
SESSION_PREPARE_LOCK_SECONDS=3
PROVIDER_INFLIGHT_JOB_CAPACITY=20
PROVIDER_INFLIGHT_TTL_SECONDS=120
MASTER_VAULT_MAX_AGE_SECONDS=43200
DEVICE_CACHE_TTL_SECONDS=86400
RATE_LIMIT_COOLDOWN_SECONDS=900
CLUSTER_WORKERS=2
CLUSTER_ENABLED=true
