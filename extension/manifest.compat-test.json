{
  "manifest_version": 3,
  "name": "Vidgen Flow Compatibility Test",
  "version": "1.0.4",
  "description": "Test-only Vidgen Flow build with environment compatibility instrumentation enabled.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Vidgen Flow",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "cookies",
    "scripting",
    "proxy",
    "privacy",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://api.vidgen.fun/*",
    "https://labs.google/*",
    "https://labs.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://labs.google/*", "https://labs.google.com/*"],
      "js": ["content/env-compat-fixture.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["https://labs.google/*", "https://labs.google.com/*"],
      "js": ["content/flow-gate.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://labs.google/fx/api/auth/signout*"],
      "js": ["content/auto-signout-iso.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://labs.google/fx/tools/flow*"],
      "js": ["content/env-compat-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://labs.google/fx/tools/flow*"],
      "js": ["content/watchdog-iso.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://labs.google/fx/tools/flow*"],
      "js": ["content/watchdog-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
